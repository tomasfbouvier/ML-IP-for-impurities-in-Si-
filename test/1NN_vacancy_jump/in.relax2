units metal
atom_style	atomic
boundary	p p p

read_data  ${input}	

pair_style hybrid/overlay eam/fs tabgap nep
pair_coeff * * eam/fs ../../${X}/${X}-Si.eam.fs Si ${X} 
pair_coeff * * tabgap ../../${X}/${X}-Si.tabgap Si ${X} no yes 
pair_coeff * * nep nep.txt Si NULL 


timestep 0.001
thermo 100

min_style 	cg
#min_modify dmax 0.01
fix 1 all recenter INIT INIT INIT
#fix 2 all box/relax aniso 0.0 #vmax 0.1
minimize 1.0e-7 1.0e-8 1000 1000

write_data ${output}

clear

